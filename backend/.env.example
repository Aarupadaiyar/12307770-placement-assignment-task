# Copy this file to .env and fill in real values. Never commit .env.

# Postgres connection string
DATABASE_URL=DATABASE_URL="postgresql://postgres:postgre@localhost:5433/shared_expenses"

# JWT signing secret (Module 2)
JWT_SECRET="super-secret-key-123"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
FRONTEND_ORIGIN="http://localhost:3000"

# FX rate API (Module 5/6 - historical USD->INR rates)
