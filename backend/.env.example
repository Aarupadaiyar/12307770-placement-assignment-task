# Copy this file to .env and fill in real values. Never commit .env.

# Postgres connection string
DATABASE_URL="postgresql://USERNAME:PASSWORD@HOST/DATABASE"
# JWT signing secret (Module 2)
JWT_SECRET="your-secret-here"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
# FRONTEND_ORIGIN accepts comma-separated origins
FRONTEND_ORIGIN="http://localhost:3000,https://flattrackplanner.netlify.app"

# FX rate API (Module 5/6 - historical USD->INR rates)
# Using frankfurter.app (free, no key required) as primary source.
# FX_API_BASE_URL="https://api.frankfurter.app"
