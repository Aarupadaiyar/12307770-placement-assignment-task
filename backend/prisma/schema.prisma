generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String            @id @default(cuid())
  email               String            @unique
  passwordHash        String
  displayName         String
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  auditLogs           AuditLog[]
  splits              ExpenseSplit[]
  expensesPaid        Expense[]         @relation("ExpensePaidBy")
  groupMembers        GroupMember[]
  memberships         GroupMembership[]
  settlementsSent     Settlement[]      @relation("SettlementFrom")
  settlementsReceived Settlement[]      @relation("SettlementTo")
  aliases             UserAlias[]

  @@map("users")
}

model UserAlias {
  id        String   @id @default(cuid())
  rawValue  String   @unique
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_aliases")
}

model Group {
  id                  String               @id @default(cuid())
  name                String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  csvIdentityMappings CsvIdentityMapping[]
  expenses            Expense[]
  groupMembers        GroupMember[]
  memberships         GroupMembership[]
  importJobs          ImportJob[]
  settlements         Settlement[]

  @@map("groups")
}

model GroupMember {
  id                String               @id @default(cuid())
  groupId           String
  userId            String?
  displayName       String
  hasAccount        Boolean              @default(false)
  isPlaceholder     Boolean              @default(false)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  approvedMappings  CsvIdentityMapping[] @relation("ApprovedMapping")
  suggestedMappings CsvIdentityMapping[] @relation("SuggestedMapping")
  expenseSplits     ExpenseSplit[]
  group             Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user              User?                @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@index([groupId])
  @@map("group_members")
}

model CsvIdentityMapping {
  id                String           @id @default(cuid())
  groupId           String
  originalName      String
  normalizedName    String
  suggestedMemberId String?
  confidence        Float            @default(0)
  approvedMemberId  String?
  decision          CsvMappingStatus @default(PENDING)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  approvedMember    GroupMember?     @relation("ApprovedMapping", fields: [approvedMemberId], references: [id])
  group             Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  suggestedMember   GroupMember?     @relation("SuggestedMapping", fields: [suggestedMemberId], references: [id])

  @@unique([groupId, originalName])
  @@index([groupId])
  @@map("csv_identity_mappings")
}

model GroupMembership {
  id        String    @id @default(cuid())
  userId    String
  groupId   String
  role      GroupRole @default(MEMBER)
  joinedAt  DateTime
  leftAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, groupId])
  @@index([groupId])
  @@map("group_memberships")
}

model Expense {
  id                String         @id @default(cuid())
  groupId           String
  description       String
  date              DateTime
  amount            Decimal        @db.Decimal(12, 2)
  currency          Currency
  splitType         SplitType
  amountInr         Decimal?       @db.Decimal(12, 2)
  fxRateToInr       Decimal?       @db.Decimal(10, 4)
  fxRateDate        DateTime?
  paidById          String
  importedFromRowId String?        @unique
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  splits            ExpenseSplit[]
  group             Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  importedFromRow   ImportRow?     @relation(fields: [importedFromRowId], references: [id])
  paidBy            User           @relation("ExpensePaidBy", fields: [paidById], references: [id])

  @@index([groupId, date])
  @@map("expenses")
}

model ExpenseSplit {
  id            String       @id @default(cuid())
  expenseId     String
  userId        String?
  groupMemberId String?
  amount        Decimal      @db.Decimal(12, 2)
  shareValue    Decimal?     @db.Decimal(10, 4)
  expense       Expense      @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  groupMember   GroupMember? @relation(fields: [groupMemberId], references: [id])
  user          User?        @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
  @@unique([expenseId, groupMemberId])
  @@index([userId])
  @@index([groupMemberId])
  @@map("expense_splits")
}

model Settlement {
  id                String     @id @default(cuid())
  groupId           String
  fromUserId        String
  toUserId          String
  amount            Decimal    @db.Decimal(12, 2)
  date              DateTime
  notes             String?
  importedFromRowId String?    @unique
  createdAt         DateTime   @default(now())
  fromUser          User       @relation("SettlementFrom", fields: [fromUserId], references: [id])
  group             Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  importedFromRow   ImportRow? @relation(fields: [importedFromRowId], references: [id])
  toUser            User       @relation("SettlementTo", fields: [toUserId], references: [id])

  @@index([groupId])
  @@map("settlements")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String
  beforeData Json?
  afterData  Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@map("audit_logs")
}

model ImportJob {
  id               String           @id @default(cuid())
  groupId          String
  fileName         String
  status           ImportJobStatus  @default(PROCESSING)
  totalRows        Int
  uploadedById     String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  committedAt      DateTime?
  participantNames Json?
  mappingComplete  Boolean          @default(false)
  decisions        ImportDecision[]
  group            Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  report           ImportReport?
  rows             ImportRow[]

  @@map("import_jobs")
}

model ImportRow {
  id                  String          @id @default(cuid())
  importJobId         String
  rowNumber           Int
  rawData             Json
  resolvedData        Json?
  status              ImportRowStatus @default(PENDING)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  resultingExpense    Expense?
  anomalies           ImportAnomaly[]
  decisions           ImportDecision?
  importJob           ImportJob       @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  resultingSettlement Settlement?

  @@index([importJobId, status])
  @@map("import_rows")
}

model ImportAnomaly {
  id              String          @id @default(cuid())
  importRowId     String
  anomalyType     AnomalyType
  severity        AnomalySeverity
  rowNumber       Int
  description     String
  suggestedAction String
  resolvedAt      DateTime?
  resolvedById    String?
  importRow       ImportRow       @relation(fields: [importRowId], references: [id], onDelete: Cascade)

  @@map("import_anomalies")
}

model ImportDecision {
  id              String            @id @default(cuid())
  importJobId     String
  importRowId     String            @unique
  resolution      AnomalyResolution
  decisionDetails Json?
  resolvedById    String
  resolvedAt      DateTime          @default(now())
  importJob       ImportJob         @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  importRow       ImportRow         @relation(fields: [importRowId], references: [id], onDelete: Cascade)

  @@map("import_decisions")
}

model ImportReport {
  id              String    @id @default(cuid())
  importJobId     String    @unique
  totalRows       Int
  cleanRows       Int
  anomaliesCount  Int
  resolvedCount   Int
  excludedCount   Int
  duplicatesCount Int
  summaryData     Json?
  createdAt       DateTime  @default(now())
  importJob       ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@map("import_reports")
}

enum SplitType {
  EQUAL
  PERCENTAGE
  SHARE
  UNEQUAL
}

enum Currency {
  INR
  USD
}

enum GroupRole {
  ADMIN
  MEMBER
}

enum AnomalyType {
  DUPLICATE_EXPENSE
  NEAR_DUPLICATE_EXPENSE
  NEGATIVE_AMOUNT
  MISSING_PAYER
  INVALID_AMOUNT
  INVALID_DATE
  UNKNOWN_MEMBER
  EXPENSE_BEFORE_MEMBER_JOINED
  EXPENSE_AFTER_MEMBER_LEFT
  SETTLEMENT_LOGGED_AS_EXPENSE
  CURRENCY_MISMATCH
  USD_CONVERSION_REQUIRED
  SPLIT_MISMATCH
  TOTAL_SPLIT_NOT_EQUAL_TO_AMOUNT
  UNKNOWN_SPLIT_TYPE
  MISSING_CATEGORY
  INVALID_PARTICIPANT_LIST
}

enum AnomalySeverity {
  INFO
  WARNING
  ERROR
}

enum ImportJobStatus {
  PROCESSING
  AWAITING_MAPPING
  IN_REVIEW
  READY
  COMMITTED
  FAILED
}

enum ImportRowStatus {
  PENDING
  CLEAN
  RESOLVED
  COMMITTED
  EXCLUDED
}

enum AnomalyResolution {
  ACCEPT_SUGGESTED
  EDIT_AND_ACCEPT
  EXCLUDE_ROW
  MARK_AS_DUPLICATE_OF
}

enum CsvMappingStatus {
  PENDING
  MAPPED
  AUTO_MAPPED
  IGNORED
}
